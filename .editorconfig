root = true

[*.kt]
# @Composable functions are PascalCase by Jetpack Compose convention. ktlint's
# standard function-naming rule (surfaced in the IDE) flags them as false positives;
# the real naming check lives in detekt's naming>FunctionNaming (ignoreAnnotated:
# ['Composable', 'Test']) and detekt's formatting FunctionName rule is already inactive.
# Disabling the ktlint rule here keeps the IDE consistent with the CI detekt policy.
ktlint_standard_function-naming = disabled
